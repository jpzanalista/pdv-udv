# ---- Banco ----
# Padrão = host (dev:host / db:migrate / db:seed). O docker-compose sobrescreve
# para "postgres:5432" no container da api. Porta 5440 evita conflito local.
# DATABASE_URL: usado por migrações e scripts (conecta como superusuário → ignora RLS).
DATABASE_URL=postgresql://pdv:pdv@localhost:5440/pdv
# DATABASE_URL_APP: a API conecta como este papel de aplicação (sujeito a RLS).
# Só ative depois de aplicar a migração de RLS. Em produção, troque a senha do pdv_app.
DATABASE_URL_APP=postgresql://pdv_app:pdv_app@localhost:5440/pdv

# ---- Nosso JWT (token exchange) — OBRIGATÓRIOS (a API não sobe sem eles) ----
JWT_SECRET=troque-em-producao
JWT_REFRESH_SECRET=troque-em-producao-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Cognito (REUNI) — validação no backend ----
COGNITO_USER_POOL_ID=us-east-1_QCJtSIWeq
COGNITO_CLIENT_ID=4heu0nghf370dks1kt7lfob0m5
COGNITO_REGION=us-east-1

# ---- ASAAS (use a chave de SANDBOX no dev) ----
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
# Token do webhook — OBRIGATÓRIO p/ o webhook funcionar (fail-closed se ausente).
ASAAS_WEBHOOK_TOKEN=

# ---- WhatsApp (Evolution API self-hosted) ----
# Sem estas, em produção o envio FALHA (não loga o código). Em dev, cai no log.
EVOLUTION_URL=
EVOLUTION_INSTANCE=
EVOLUTION_API_KEY=

# ---- Gestor da Plataforma (login único, sem núcleo) ----
GESTOR_EMAIL=jpzanalista@gmail.com
GESTOR_SENHA_HASH=

# ---- Segurança / rede ----
# Origens permitidas além de localhost/LAN e *.emporio.cloud (separadas por vírgula).
CORS_ORIGINS=
# Desliga o agendador do corte quando necessário: CORTE_SCHEDULER=off

# ---- API / Web ----
API_PORT=3333
NEXT_PUBLIC_API_URL=http://localhost:3333
