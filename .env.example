# ---- Banco ----
# Padrão = host (dev:host / db:migrate / db:seed). O docker-compose sobrescreve
# para "postgres:5432" no container da api. Porta 5440 evita conflito local.
DATABASE_URL=postgresql://pdv:pdv@localhost:5440/pdv

# ---- Nosso JWT (token exchange) ----
JWT_SECRET=troque-em-producao
JWT_REFRESH_SECRET=troque-em-producao-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Cognito (REUNI) — validação no backend ----
COGNITO_USER_POOL_ID=us-east-1_QCJtSIWeq
COGNITO_CLIENT_ID=4heu0nghf370dks1kt7lfob0m5
COGNITO_REGION=us-east-1

# ---- ASAAS (use a chave de SANDBOX no dev) ----
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=

# ---- API / Web ----
API_PORT=3333
NEXT_PUBLIC_API_URL=http://localhost:3333
